{
  "name": "@paperclipai/electron",
  "version": "0.1.0",
  "private": true,
  "description": "Paperclip desktop application",
  "author": {
    "name": "Paperclip AI",
    "email": "hello@paperclipai.com"
  },
  "homepage": "https://github.com/paperclipai/paperclip",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc",
    "start": "electron dist/main.js",
    "prepare-server": "node scripts/prepare-server.mjs",
    "pack": "pnpm build && pnpm prepare-server && electron-builder --dir",
    "dist": "pnpm build && pnpm prepare-server && electron-builder",
    "dist:mac": "pnpm build && pnpm prepare-server && electron-builder --mac",
    "dist:mac-universal": "pnpm build && pnpm prepare-server && electron-builder --mac --universal",
    "dist:win": "pnpm build && pnpm prepare-server && electron-builder --win"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  }
}
